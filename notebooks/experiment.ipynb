import pandas as pd
import matplotlib.pyplot as plt

df = pd.read_csv("results.csv")

summary = df.groupby(["model","condition"]).mean().reset_index()

print(summary)

clean = summary[summary["condition"] == "clean"]

plt.scatter(clean["latency"], clean["wer"])

for i,row in clean.iterrows():
    plt.text(row["latency"], row["wer"], row["model"])

plt.xlabel("Latency (s)")
plt.ylabel("WER")
plt.title("Accuracy vs Latency Tradeoff")

plt.show()
